COMPOSE_PROJECT_NAME=wrenai
PLATFORM=linux/amd64

PROJECT_DIR=.

# Service Ports
WREN_ENGINE_PORT=8080
WREN_ENGINE_SQL_PORT=7432
WREN_AI_SERVICE_PORT=5555
WREN_UI_PORT=3000
IBIS_SERVER_PORT=8000
WREN_UI_ENDPOINT=http://wren-ui:3000

# AI Service Settings
QDRANT_HOST=qdrant
SHOULD_FORCE_DEPLOY=1

# ============================================================
# VERTEX AI AUTHENTICATION
# KHONG can API key. Xac thuc bang Google Cloud IAM:
#   gcloud auth application-default login
# Dang nhap bang email @st.uel.edu.vn da duoc cap quyen
# ============================================================
VERTEXAI_PROJECT=project-ba49e1b7-26e0-4cbf-a14
VERTEXAI_LOCATION=us-central1

# Versions
WREN_PRODUCT_VERSION=0.29.1
WREN_ENGINE_VERSION=0.22.0
WREN_AI_SERVICE_VERSION=0.29.0
IBIS_SERVER_VERSION=0.22.0
WREN_UI_VERSION=0.32.2
WREN_BOOTSTRAP_VERSION=0.1.5

# User UUID (chay lenh sau de tao: [guid]::NewGuid().ToString())
USER_UUID=

# Telemetry
POSTHOG_API_KEY=phc_nhF32aj4xHXOZb0oqr2cn4Oy9uiWzz6CCP4KZmRq9aE
POSTHOG_HOST=https://app.posthog.com
TELEMETRY_ENABLED=false

# Model display name
GENERATION_MODEL=vertex_ai/gemini-2.5-flash

# Host port mapping
HOST_PORT=3000
AI_SERVICE_FORWARD_PORT=5555

# Wren UI
EXPERIMENTAL_ENGINE_RUST_VERSION=false

# Local Storage
LOCAL_STORAGE=.
